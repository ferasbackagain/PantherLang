  "known_limitations": [
    "No true concurrency: All 'concurrent' operations are simulated sequentially",
    "No actual async/await: Language doesn't support async/await syntax; functions are synchronous simulations",
    "No true channels: Channel operations are simulated with arrays",
    "No real futures: Promise/future operations are synchronous simulations",
    "No thread safety: Not thread-safe; single-threaded simulation only",
    "Test framework is basic: No try/catch, limited assertions, no fixtures",
    "Duplicate functions removed between testing/async/concurrent packages"
  ],
