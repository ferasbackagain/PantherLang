{
  "name": "pantherlang-official",
  "displayName": "PantherLang",
  "description": "Official PantherLang language support, project wizard, run/build/debug tooling, and AI agent knowledge pack for Visual Studio Code.",
  "version": "1.1.3",
  "publisher": "PantherLang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Debuggers",
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onCommand:pantherlang.buildProject",
    "onCommand:pantherlang.debugProject",
    "onCommand:pantherlang.doctor",
    "onCommand:pantherlang.newAiProject",
    "onCommand:pantherlang.newApiProject",
    "onCommand:pantherlang.newConsoleProject",
    "onCommand:pantherlang.newProject",
    "onCommand:pantherlang.newWebProject",
    "onCommand:pantherlang.openAgentGuide",
    "onCommand:pantherlang.runCurrentFile",
    "onCommand:pantherlang.runFile",
    "onLanguage:panther",
    "onLanguage:pantherlang",
    "onDebug",
    "onCommand:panther.debug.start",
    "onDebugResolve:panther",
    "onDebugInitialConfigurations"
  ],
  "contributes": {
    "languages": [
      {
        "id": "panther",
        "aliases": [
          "PantherLang",
          "panther"
        ],
        "extensions": [
          ".panther",
          ".pan"
        ],
        "configuration": "./language-configuration/panther-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "panther",
        "scopeName": "source.panther",
        "path": "./syntaxes/panther.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "pantherlang.newProject",
        "title": "PantherLang: New Project"
      },
      {
        "command": "pantherlang.newConsoleProject",
        "title": "PantherLang: New Console Project"
      },
      {
        "command": "pantherlang.newWebProject",
        "title": "PantherLang: New Web Project"
      },
      {
        "command": "pantherlang.newApiProject",
        "title": "PantherLang: New API Project"
      },
      {
        "command": "pantherlang.newAiProject",
        "title": "PantherLang: New AI Project"
      },
      {
        "command": "pantherlang.runCurrentFile",
        "title": "PantherLang: Run Current File"
      },
      {
        "command": "pantherlang.runFile",
        "title": "PantherLang: Run Current File"
      },
      {
        "command": "pantherlang.buildProject",
        "title": "PantherLang: Build Project"
      },
      {
        "command": "pantherlang.debugProject",
        "title": "PantherLang: Debug Project"
      },
      {
        "command": "pantherlang.doctor",
        "title": "PantherLang: Doctor"
      },
      {
        "command": "pantherlang.openAgentGuide",
        "title": "PantherLang: Open Agent Guide"
      },
      {
        "command": "panther.debug.start",
        "title": "Panther: Start Debugging"
      }
    ],
    "debuggers": [
      {
        "type": "panther",
        "label": "PantherLang Debug",
        "languages": [
          "panther",
          "pantherlang"
        ],
        "program": "./out/extension.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the PantherLang program to debug.",
                "default": "${workspaceFolder}/examples/hello.pan"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory.",
                "default": "${workspaceFolder}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at program entry.",
                "default": false
              },
              "dryRun": {
                "type": "boolean",
                "description": "Run Panther Debug Adapter in dry-run verification mode.",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Debug PantherLang File",
            "type": "panther",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": true,
            "dryRun": true
          }
        ]
      },
      {
        "type": "pantherlang",
        "label": "PantherLang",
        "program": "./out/extension.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the PantherLang program."
              },
              "dryRun": {
                "type": "boolean",
                "default": true,
                "description": "Prepare debug launch without executing a real runtime."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pantherlang",
            "request": "launch",
            "name": "Debug PantherLang Program",
            "program": "${workspaceFolder}/src/main.panther",
            "dryRun": true
          }
        ]
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "pantherlang.newProject"
        },
        {
          "command": "pantherlang.newConsoleProject"
        },
        {
          "command": "pantherlang.newWebProject"
        },
        {
          "command": "pantherlang.newApiProject"
        },
        {
          "command": "pantherlang.newAiProject"
        },
        {
          "command": "pantherlang.runCurrentFile"
        },
        {
          "command": "pantherlang.runFile"
        },
        {
          "command": "pantherlang.buildProject"
        },
        {
          "command": "pantherlang.debugProject"
        },
        {
          "command": "pantherlang.doctor"
        },
        {
          "command": "pantherlang.openAgentGuide"
        }
      ]
    },
    "iconThemes": [
      {
        "id": "pantherlang-icons",
        "label": "PantherLang Icons",
        "path": "./icons/pantherlang-icon-theme.json"
      }
    ]
  },
  "main": "./out/extension.js",
  "scripts": {
    "compile": "echo PantherLang extension uses checked-in out/extension.js",
    "test": "echo PantherLang VS Code extension tests are handled by Panther regression"
  },
  "files": [
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "assets/**",
    "language-configuration.json",
    "syntaxes/**",
    "out/**",
    "src/**",
    "project_templates/**",
    "tools/project_wizard/**",
    "icons/**"
  ],
  "keywords": [
    "agent-guide",
    "ai-agent",
    "build",
    "compiler",
    "copilot",
    "debugger",
    "deploy",
    "developer-tools",
    "documentation",
    "examples",
    "language-server",
    "panther",
    "pantherlang",
    "programming-language",
    "project-wizard",
    "run",
    "templates",
    "vscode-extension"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/feras-khatib/pantherlang.git"
  },
  "bugs": {
    "url": "https://github.com/feras-khatib/pantherlang/issues"
  },
  "homepage": "https://github.com/feras-khatib/pantherlang",
  "galleryBanner": {
    "color": "#0B1F3A",
    "theme": "dark"
  },
  "icon": "assets/pantherlang-icon.png"
}
