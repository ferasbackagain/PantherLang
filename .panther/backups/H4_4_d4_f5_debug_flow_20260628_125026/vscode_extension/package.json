{
  "name": "pantherlang",
  "displayName": "PantherLang",
  "description": "PantherLang language support for VS Code",
  "version": "0.8.8",
  "publisher": "pantherlang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onLanguage:panther",
    "onDebug",
    "onDebugResolve:panther",
    "onDebugInitialConfigurations",
    "onCommand:panther.debug.start"
  ],
  "contributes": {
    "languages": [
      {
        "id": "panther",
        "aliases": [
          "PantherLang",
          "panther"
        ],
        "extensions": [
          ".panther",
          ".pan"
        ],
        "configuration": "./language-configuration/panther-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "panther",
        "scopeName": "source.panther",
        "path": "./syntaxes/panther.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "panther.runFile",
        "title": "Panther: Run Current File"
      },
      {
        "command": "panther.checkFile",
        "title": "Panther: Check Current File"
      },
      {
        "command": "panther.formatFile",
        "title": "Panther: Format Current File"
      },
      {
        "command": "panther.debug.start",
        "title": "PantherLang: Start Debugging"
      }
    ],
    "debuggers": [
      {
        "type": "panther",
        "label": "PantherLang Debug",
        "languages": [
          "panther",
          "pantherlang"
        ],
        "program": "./out/extension.js",
        "runtime": "node",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the PantherLang program to debug.",
                "default": "${workspaceFolder}/examples/hello.pan"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory.",
                "default": "${workspaceFolder}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop at program entry.",
                "default": false
              },
              "dryRun": {
                "type": "boolean",
                "description": "Run Panther Debug Adapter in dry-run verification mode.",
                "default": true
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Debug PantherLang File",
            "type": "panther",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": true,
            "dryRun": true
          }
        ]
      }
    ]
  },
  "main": "./out/extension.js"
}
