panther main {
    print "=== Lesson 01: Expressions & Operators ===";
    
    // Arithmetic
    print string(10 + 5 * 2);
    print string((10 + 5) * 2);
    print string(pow(2, 10));
    
    // Comparison
    print string(10 > 5);
    print string(10 == 10);
    print string("a" < "b");
    
    // Logical
    print string(true && false);
    print string(true || false);
    print string(!true);
    
    // String concat
    print "Hello " + "World";
}
