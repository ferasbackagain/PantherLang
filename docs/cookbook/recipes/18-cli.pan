panther main {
    print "PantherLang CLI features:";
    print "  run     - execute a .pan file";
    print "  build   - compile to standalone";
    print "  check   - syntax + semantic validation";
    print "  new     - scaffold a project";
    print "  doctor  - system diagnostics";
    print "";
    print "Example: panther run this_file.pan";
    print "cross-platform: Linux, macOS, Windows";
}
